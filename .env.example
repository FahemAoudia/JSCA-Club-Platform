# Mot de passe de l’espace gestion JSCA (/dashboard après connexion sur /dashboard/login)
ADMIN_PASSWORD=jsca-admin

# Base de données PostgreSQL
# Vercel Postgres fournit souvent POSTGRES_URL ; Neon / autres fournissent souvent DATABASE_URL.
# L’app accepte les deux (priorité: POSTGRES_URL puis DATABASE_URL).
# POSTGRES_URL=postgresql://user:pass@host:5432/db?sslmode=require
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Contact form (SMTP) — optional
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_user
# SMTP_PASS=your_pass
# CONTACT_TO_EMAIL=jscaghbalou@gmail.com
# CONTACT_FROM_EMAIL=no-reply@your-domain.com
